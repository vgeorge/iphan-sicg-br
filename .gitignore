# Generated by build/fetch.py. The Parquet outputs ARE committed (small, ~3 MB) so the
# static site ships with its data. The raw fetch cache is large/regenerable -> ignored.
data/raw/

# One-time vendoring tooling (esbuild + duckdb-wasm/apache-arrow sources).
# The bundled output vendor/duckdb/duckdb.mjs IS committed; only this scratch dir isn't.
build/_bundle/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node (build/_bundle only; no app build step)
node_modules/

